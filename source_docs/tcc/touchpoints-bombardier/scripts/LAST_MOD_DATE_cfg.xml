<?xml version="1.0" encoding="UTF-8"?>
<cli:ClientConfig xmlns:cli="http://www.taleo.com/ws/integration/client">
    <cli:Global>
        <cli:General>
            <cli:ConfigurationIdentifier>LAST_MOD_DATE</cli:ConfigurationIdentifier>
            <cli:WorkflowIdentifier>
                <cli:Template>Export-Candidate-[NOW]</cli:Template>
            </cli:WorkflowIdentifier>
            <cli:Type>T-SOAP</cli:Type>
            <cli:Communication>PRODUCT</cli:Communication>
            <cli:ProductCode>RC1502</cli:ProductCode>
            <cli:TSOAPFormatVersion>210</cli:TSOAPFormatVersion>
            <cli:RequestMessage>
                <cli:File>
                    <cli:SpecificFile>[CFGFOLDER]/LAST_MOD_DATE_sq.xml</cli:SpecificFile>
                </cli:File>
                <cli:Format>SQ-XML</cli:Format>
                <cli:Encoding>UTF-8</cli:Encoding>
            </cli:RequestMessage>
            <cli:ResponseMessage>
                <cli:File>
                    <cli:SpecificFile>[OUTBOUND_FOLDER]/LAST_MOD_DATE.r.csv</cli:SpecificFile>
                </cli:File>
                <cli:Format>CSV</cli:Format>
                <cli:Encoding>UTF-8</cli:Encoding>
            </cli:ResponseMessage>
            <cli:TemporaryFilesFolder>[TEMP_FOLDER]</cli:TemporaryFilesFolder>
            <cli:DeleteTemporaryFiles>false</cli:DeleteTemporaryFiles>
        </cli:General>
        <cli:Monitoring>
            <cli:Folder>[MONITOR_FOLDER]</cli:Folder>
            <cli:FileName>
                <cli:WorkflowIdentifier/>
            </cli:FileName>
            <cli:Type>
                <cli:XML/>
                <cli:HTML/>
                <cli:Text/>
            </cli:Type>
        </cli:Monitoring>
        <cli:Alerting>
            <cli:Transports>
                <cli:Email>
                    <cli:Host>INSERT MAIL HOST</cli:Host>
                    <cli:Port>25</cli:Port>
                </cli:Email>
            </cli:Transports>
            <cli:OnError/>
            <cli:OnComplete/>
        </cli:Alerting>
        <cli:Board>
            <cli:BaseBoard/>
        </cli:Board>
    </cli:Global>
    <cli:Steps>
        <cli:PreProcess>
            <cli:PrepareQuery xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.paging.PagingPreStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>pagingSize</cli:Name>
                        <cli:Value>50000</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>pagingFilename</cli:Name>
                        <cli:Value>[OUTBOUND_FOLDER]/LAST_MOD_DATE.pgn</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:WrapSoap xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                <cli:WorkflowIdentifier/>
                <cli:Action>http://www.taleo.com/ws/integration/toolkit/2005/07/action/export</cli:Action>
            </cli:WrapSoap>
        </cli:PreProcess>
        <cli:Process>
            <cli:Send>
                <cli:Endpoint source="SELECTION" sourceName="bombardier.taleo.net"/>
                <cli:Quality>
                    <cli:Retry>
                        <cli:Interval>30</cli:Interval>
                        <cli:CompletionAttempts>2</cli:CompletionAttempts>
                        <cli:IgnoreErrors>true</cli:IgnoreErrors>
                    </cli:Retry>
                </cli:Quality>
                <cli:Validate>false</cli:Validate>
            </cli:Send>
            <cli:Poll>
                <cli:Endpoint source="SELECTION" sourceName="bombardier.taleo.net"/>
                <cli:Quality>
                    <cli:Retry>
                        <cli:Interval>10</cli:Interval>
                        <cli:CompletionAttempts>30</cli:CompletionAttempts>
                        <cli:IgnoreErrors>true</cli:IgnoreErrors>
                    </cli:Retry>
                </cli:Quality>
            </cli:Poll>
            <cli:Retrieve>
                <cli:Endpoint source="SELECTION" sourceName="bombardier.taleo.net"/>
                <cli:Quality/>
            </cli:Retrieve>
        </cli:Process>
        <cli:PostProcess>
            <cli:StripSoap xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                <cli:StrippingType>CSV</cli:StrippingType>
                <cli:FailOnError>true</cli:FailOnError>
            </cli:StripSoap>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.count.ExportCountPostStep</cli:JavaClass>
                <cli:Parameters/>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.paging.PagingPostStep</cli:JavaClass>
                <cli:Parameters/>
            </cli:CustomStep>
        </cli:PostProcess>
    </cli:Steps>
</cli:ClientConfig>