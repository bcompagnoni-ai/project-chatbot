<?xml version="1.0" encoding="UTF-8"?>
<cli:ClientConfig xmlns:cli="http://www.taleo.com/ws/integration/client">
    <cli:Global>
        <cli:General>
            <cli:ConfigurationIdentifier>impLAST_MOD_DATE</cli:ConfigurationIdentifier>
            <cli:WorkflowIdentifier>
                <cli:Template>LAST_MOD_DATE-[NOW]</cli:Template>
            </cli:WorkflowIdentifier>
            <cli:Type>T-SOAP</cli:Type>
            <cli:Communication>PRODUCT</cli:Communication>
            <cli:ProductCode>RC1502</cli:ProductCode>
            <cli:TSOAPFormatVersion>210</cli:TSOAPFormatVersion>
            <cli:RequestMessage>
                <cli:File>
                    <cli:SpecificFile>[OUTBOUND_FOLDER]/LAST_MOD_DATE.r.csv</cli:SpecificFile>
                </cli:File>
                <cli:Format>CSV</cli:Format>
                <cli:Encoding>UTF-8</cli:Encoding>
            </cli:RequestMessage>
            <cli:ResponseMessage>
                <cli:File>
                    <cli:SpecificFile>[OUTBOUND_FOLDER]/impLAST_MOD_DATE.r.csv</cli:SpecificFile>
                </cli:File>
                <cli:Format>CSV</cli:Format>
                <cli:Encoding>UTF-8</cli:Encoding>
            </cli:ResponseMessage>
            <cli:TemporaryFilesFolder>[TEMP_FOLDER]</cli:TemporaryFilesFolder>
            <cli:DeleteTemporaryFiles>true</cli:DeleteTemporaryFiles>
        </cli:General>
        <cli:Monitoring>
            <cli:Folder>[MONITOR_FOLDER]</cli:Folder>
            <cli:FileName>
                <cli:WorkflowIdentifier/>
            </cli:FileName>
            <cli:Type>
                <cli:XML/>
                <cli:HTML/>
                <cli:Text/>
            </cli:Type>
        </cli:Monitoring>
        <cli:Alerting>
            <cli:Transports>
                <cli:Email>
                    <cli:Host>INSERT MAIL HOST</cli:Host>
                    <cli:Port>25</cli:Port>
                </cli:Email>
            </cli:Transports>
            <cli:OnError/>
            <cli:OnComplete/>
        </cli:Alerting>
        <cli:Board>
            <cli:BaseBoard/>
        </cli:Board>
    </cli:Global>
    <cli:Steps>
        <cli:PreProcess>
            <cli:PrepareLoad>
                <cli:LoadFile>[CFGFOLDER]/impLAST_MOD_DATE_ld.xml</cli:LoadFile>
            </cli:PrepareLoad>
            <cli:WrapSoap xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                <cli:WorkflowIdentifier/>
                <cli:Action>http://www.taleo.com/ws/integration/toolkit/2005/07/action/import</cli:Action>
            </cli:WrapSoap>
        </cli:PreProcess>
        <cli:Process>
            <cli:Send>
                <cli:Endpoint source="SELECTION" sourceName="bombardier.taleo.net"/>
                <cli:Quality>
                    <cli:Retry>
                        <cli:Interval>30</cli:Interval>
                        <cli:CompletionAttempts>2</cli:CompletionAttempts>
                        <cli:IgnoreErrors>true</cli:IgnoreErrors>
                    </cli:Retry>
                </cli:Quality>
                <cli:Validate>false</cli:Validate>
            </cli:Send>
            <cli:Poll>
                <cli:Endpoint source="SELECTION" sourceName="bombardier.taleo.net"/>
                <cli:Quality>
                    <cli:Retry>
                        <cli:Interval>10</cli:Interval>
                        <cli:CompletionAttempts>30</cli:CompletionAttempts>
                        <cli:IgnoreErrors>true</cli:IgnoreErrors>
                    </cli:Retry>
                </cli:Quality>
            </cli:Poll>
            <cli:Retrieve>
                <cli:Endpoint source="SELECTION" sourceName="bombardier.taleo.net"/>
                <cli:Quality/>
            </cli:Retrieve>
        </cli:Process>
        <cli:PostProcess>
            <cli:TransformLoad>
                <cli:LoadFile>[CFGFOLDER]/impLAST_MOD_DATE_ld.xml</cli:LoadFile>
                <cli:OutputProperties>false</cli:OutputProperties>
                <cli:Parameters xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
            </cli:TransformLoad>
        </cli:PostProcess>
    </cli:Steps>
</cli:ClientConfig>