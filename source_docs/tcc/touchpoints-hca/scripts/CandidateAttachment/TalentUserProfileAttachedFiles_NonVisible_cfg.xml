<?xml version="1.0" encoding="UTF-8"?>
<cli:ClientConfig xmlns:cli="http://www.taleo.com/ws/integration/client">
    <cli:Global>
        <cli:General>
            <cli:ConfigurationIdentifier>TalentUserProfileAttachedFiles_NonVisible</cli:ConfigurationIdentifier>
            <cli:WorkflowIdentifier>
                <cli:Template>TalentUserAttachment_[EXTRACT_ID]-[NOW]-[LOOP_INDEX]</cli:Template>
            </cli:WorkflowIdentifier>
            <cli:Type>T-SOAP</cli:Type>
            <cli:Communication>PRODUCT</cli:Communication>
            <cli:ProductCode>RC1502</cli:ProductCode>
            <cli:TSOAPFormatVersion>210</cli:TSOAPFormatVersion>
            <cli:RequestMessage>
                <cli:File>
                    <cli:SpecificFile>[CFGFOLDER]\TalentUserProfileAttachedFiles_NonVisible_sq.xml</cli:SpecificFile>
                </cli:File>
                <cli:Format>SQ-XML</cli:Format>
                <cli:Encoding>UTF-8</cli:Encoding>
            </cli:RequestMessage>
            <cli:ResponseMessage>
                <cli:File>
                    <cli:NoFile/>
                </cli:File>
                <cli:Format>CSV</cli:Format>
                <cli:Encoding>UTF-8</cli:Encoding>
            </cli:ResponseMessage>
            <cli:TemporaryFilesFolder>[TEMP_FOLDER]</cli:TemporaryFilesFolder>
            <cli:DeleteTemporaryFiles>false</cli:DeleteTemporaryFiles>
        </cli:General>
        <cli:Monitoring>
            <cli:Folder>[MONITOR_FOLDER]</cli:Folder>
            <cli:FileName>
                <cli:WorkflowIdentifier/>
            </cli:FileName>
            <cli:Type>
                <cli:HTML/>
                <cli:Text/>
            </cli:Type>
        </cli:Monitoring>
        <cli:Alerting>
            <cli:Transports>
                <cli:Email>
                    <cli:Host>INSERT MAIL HOST</cli:Host>
                    <cli:Port>25</cli:Port>
                </cli:Email>
            </cli:Transports>
            <cli:OnError/>
            <cli:OnComplete/>
        </cli:Alerting>
        <cli:Board>
            <cli:BaseBoard/>
        </cli:Board>
    </cli:Global>
    <cli:Steps>
        <cli:PreProcess>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.paging.PagingPreStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>pagingSize</cli:Name>
                        <cli:Value>100</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>pagingFilename</cli:Name>
                        <cli:Value>[OUTBOUND_FOLDER]/TalentUserProfileAttachedFiles_NonVisible.pgn</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.control.LogContextStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>EXTRACT_ID</cli:Name>
                        <cli:Value>[EXTRACT_ID]</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.count.DailyCountPreStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>countFilename</cli:Name>
                        <cli:Value>[LOG_FOLDER]/[TALEO_ZONE]_DailyCount.log</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>maximumCount</cli:Name>
                        <cli:Value>[MAX_DAILY_COUNT]</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.lrd.LRDPreStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>dateTimeMask</cli:Name>
                        <cli:Value>[DATE_TIME_MASK]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>lrdFilename</cli:Name>
                        <cli:Value>[EXTRACT_ID]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>currentRunDate</cli:Name>
                        <cli:Value>[CURRENT_RUN_DATE]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>abortOnRerun</cli:Name>
                        <cli:Value>[ABORT_ON_RERUN]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>maxExtractDays</cli:Name>
                        <cli:Value>[TIME_INCREMENT]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>createOnly</cli:Name>
                        <cli:Value>[CREATE_ONLY]</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:PrepareQuery xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
            <cli:WrapSoap xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                <cli:WorkflowIdentifier/>
                <cli:Action>http://www.taleo.com/ws/integration/toolkit/2005/07/action/export</cli:Action>
            </cli:WrapSoap>
        </cli:PreProcess>
        <cli:Process>
            <cli:Send>
                <cli:Endpoint source="SELECTION" sourceName="hca.taleo.net"/>
                <cli:Quality>
                    <cli:Retry>
                        <cli:Interval>3</cli:Interval>
                        <cli:CompletionAttempts>2000</cli:CompletionAttempts>
                        <cli:IgnoreErrors>true</cli:IgnoreErrors>
                    </cli:Retry>
                </cli:Quality>
                <cli:Validate>false</cli:Validate>
            </cli:Send>
            <cli:Poll>
                <cli:Endpoint source="SELECTION" sourceName="hca.taleo.net"/>
                <cli:Quality>
                    <cli:Retry>
                        <cli:Interval>10</cli:Interval>
                        <cli:CompletionAttempts>3000</cli:CompletionAttempts>
                        <cli:IgnoreErrors>true</cli:IgnoreErrors>
                    </cli:Retry>
                </cli:Quality>
            </cli:Poll>
            <cli:Retrieve>
                <cli:Endpoint source="SELECTION" sourceName="hca.taleo.net"/>
                <cli:Quality/>
            </cli:Retrieve>
        </cli:Process>
        <cli:PostProcess>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.count.ExportCountPostStep</cli:JavaClass>
                <cli:Parameters/>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.control.FilterExportErrorPostStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>active</cli:Name>
                        <cli:Value>[LOOPING_ACTIVE]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>pattern</cli:Name>
                        <cli:Value>[TRANSACTION_LIMIT_PATTERN]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>exitCode</cli:Name>
                        <cli:Value>[LIMIT_EXIT_CODE]</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.control.FilterExportErrorPostStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>active</cli:Name>
                        <cli:Value>[LOOPING_ACTIVE]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>pattern</cli:Name>
                        <cli:Value>[FILE_SIZE_LIMIT_PATTERN]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>exitCode</cli:Name>
                        <cli:Value>[LIMIT_EXIT_CODE]</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.control.RaiseExportErrorPostStep</cli:JavaClass>
                <cli:Parameters/>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.count.ExportCountPostStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>countFilename</cli:Name>
                        <cli:Value>[LOG_FOLDER]/[TALEO_ZONE]_DailyCount.log</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>extractId</cli:Name>
                        <cli:Value>[EXTRACT_ID]</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:StripSoap>
                <cli:StrippingType>Document</cli:StrippingType>
                <cli:FailOnError>true</cli:FailOnError>
            </cli:StripSoap>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.xml.XslPostStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>xslFile</cli:Name>
                        <cli:Value>[CFGFOLDER]/Pre-TalentUserProfileAttachedFiles.xsl</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>outputFormat</cli:Name>
                        <cli:Value>XML</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>OUTBOUND_FOLDER</cli:Name>
                        <cli:Value>[DOCUMENT_OUTBOUND_FOLDER]\hca_TalentUserProfileAttachedFiles</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.xml.ExtractFilesPostStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>operations</cli:Name>
                        <cli:Value>DecodeBase64,Gunzip</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.xml.XslPostStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>xslFile</cli:Name>
                        <cli:Value>[CFGFOLDER]/Post-TalentUserProfileAttachedFiles.xsl</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>outputFormat</cli:Name>
                        <cli:Value>CSV</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.csv.MergePostStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>active</cli:Name>
                        <cli:Value>[MERGE_FILES]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>filePattern</cli:Name>
                        <cli:Value>[MERGE_PATTERN]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>keys</cli:Name>
                        <cli:Value>FileName2</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>removeDuplicates</cli:Name>
                        <cli:Value>[REMOVE_DUPLICATES]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>csvHeaderPresent</cli:Name>
                        <cli:Value>true</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>csvDelimiter</cli:Name>
                        <cli:Value>|</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>csvQuoteCharacter</cli:Name>
                        <cli:Value>"</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>deleteMergedFiles</cli:Name>
                        <cli:Value>false</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.file.WriteFileStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>filename</cli:Name>
                        <cli:Value>[OUTBOUND_FOLDER]/[OUTPUT_FILE]</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.file.DeleteFileStep</cli:JavaClass>
                <cli:Parameters>
                    <cli:Parameter>
                        <cli:Name>active</cli:Name>
                        <cli:Value>[MERGE_FILES]</cli:Value>
                    </cli:Parameter>
                    <cli:Parameter>
                        <cli:Name>filePattern</cli:Name>
                        <cli:Value>[DEFERRED_MERGE_FOLDER]/[EXTRACT_ID]/*</cli:Value>
                    </cli:Parameter>
                </cli:Parameters>
            </cli:CustomStep>
            <cli:CustomStep>
                <cli:JavaClass>com.taleo.integration.client.customstep.paging.PagingPostStep</cli:JavaClass>
                <cli:Parameters/>
            </cli:CustomStep>
        </cli:PostProcess>
    </cli:Steps>
</cli:ClientConfig>